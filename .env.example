# ============================================================
# TPEC-IA — Variáveis de ambiente para deploy (Netlify / Lovable Cloud)
# ============================================================
# NUNCA comite este arquivo preenchido no repositório.
# Copie para .env localmente ou cadastre-as no dashboard da hospedagem.

# ------------------------------------------------------------------
# 1) SUPABASE PRINCIPAL (Lovable Cloud / TPEC-IA)
# ------------------------------------------------------------------
# Essas variáveis são gerenciadas automaticamente pelo Lovable Cloud,
# mas precisam ser replicadas manualmente no Netlify (Site settings → Environment variables).
# No Lovable Cloud: Project Settings → Integrations → Supabase.

# URL do projeto Supabase principal
SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Chave publicável (anon/publishable) — pode aparecer no frontend
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do projeto Supabase (usado por algumas integrações)
SUPABASE_PROJECT_ID=<project-ref>
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Chave de service role — SOMENTE servidor. NUNCA expor no frontend.
# No Lovable Cloud essa chave não é acessível diretamente; o backend gerencia.
# Se estiver no Netlify, você precisa obtê-la em Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# 2) CHAVES DE APIs EXTERNAS
# ------------------------------------------------------------------

# Perplexity API — obrigatória para respostas da IA.
# Obtenha em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Lovable AI Gateway — usada para gerar embeddings via Gemini.
# O Lovable Cloud provisiona automaticamente LOVABLE_API_KEY.
# Se estiver no Netlify, habilite a AI Gateway em Lovable → Settings → AI Gateway.
LOVABLE_API_KEY=lovable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# 3) SUPABASE SECUNDÁRIO (site DuKamp)
# ------------------------------------------------------------------
# Esses dados vêm do segundo Supabase conectado (site da DuKamp).
# Use a chave anon/publishable desse projeto, NÃO a service_role.

DUKAMP_SITE_SUPABASE_URL=https://<dukamp-project-ref>.supabase.co
DUKAMP_SITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# 4) OPCIONAIS / SEGURANÇA
# ------------------------------------------------------------------
# NODE_ENV=production
# RATE_LIMIT_MAX=15
# RATE_LIMIT_WINDOW_MS=60000
