# TPEC-IA — variáveis de ambiente

# Chave da API da Perplexity (obrigatória). Nunca comitar no repositório.
# Obtenha em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LOVABLE_API_KEY (auto-provisionada pelo Lovable Cloud — usada para gerar
# embeddings via Gemini no gateway ai.gateway.lovable.dev). NÃO defina manualmente.

# SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY também
# são gerenciados pelo Lovable Cloud automaticamente.
